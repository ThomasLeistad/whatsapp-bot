# =============================================
# CONFIGURACIÓN WHATSAPP COBRANZAS — ONLYSOFT
# =============================================
# Copiá este archivo como .env y completá los valores

# --- Base de Datos MySQL ---
# Si usás el docker-compose incluido, apuntá a "db" (nombre del servicio)
# Si usás tu DB de Onlysoft existente, poné la IP/hostname de ese servidor
DB_HOST=db
DB_PORT=3306
DB_USER=wa_bot
DB_PASSWORD=cambiar_password_seguro
DB_NAME=onlysoft
DB_ROOT_PASSWORD=cambiar_root_password  # Solo si usás el MySQL del docker-compose

# --- Servidor Web (Dashboard) ---
PORT=3000
SESSION_SECRET=cambiar_por_clave_aleatoria_larga_aqui_abc123xyz

# --- Admin del Dashboard Web ---
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar_esto_urgente

# --- WhatsApp ---
# Número del administrador que recibirá las consultas de validación
# Formato: código_país + código_área + número (sin espacios ni guiones)
# Argentina: 54 (país) + 9 (prefijo celular) + 11 (área) + XXXXXXXX (número)
# Ejemplo: 5491112345678@c.us
ADMIN_WHATSAPP_NUMBER=5491112345678@c.us

# --- Directorios (no cambiar si usás Docker) ---
COMPROBANTES_DIR=./comprobantes
SESSIONS_DIR=./sessions
LOGS_DIR=./logs

# --- OCR ---
# Idioma para Tesseract. "spa" = español (instalado en el Dockerfile)
TESSERACT_LANG=spa

# --- Matching Fuzzy ---
# Umbral de similitud para match AUTOMÁTICO (0.0 a 1.0)
# 0.8 = 80% similitud → acredita solo
# 0.6 = 60% similitud → pide confirmación al admin
# Recomendado: empezar en 0.8 y bajar si hay falsos negativos
FUZZY_THRESHOLD=0.8

# --- Logs ---
# Niveles: error | warn | info | debug
LOG_LEVEL=info
