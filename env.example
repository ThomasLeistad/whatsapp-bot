# =============================================
# CONFIGURACIÓN WHATSAPP COBRANZAS - ONLYSOFT
# =============================================

# --- Base de Datos MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_NAME=tu_base_de_datos

# --- Servidor Web (Dashboard) ---
PORT=3000
SESSION_SECRET=cambiar_por_una_clave_segura_aleatoria

# --- Admin del Sistema ---
# Usuario para el dashboard web
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar_esto

# --- WhatsApp ---
# Número del admin que recibirá las consultas de validación (formato: 5491112345678@c.us)
# El prefijo 549 es Argentina: 54 (país) + 9 (para celulares)
ADMIN_WHATSAPP_NUMBER=5491112345678

# --- Directorios ---
COMPROBANTES_DIR=./comprobantes
SESSIONS_DIR=./sessions

# --- OCR ---
# Idioma para Tesseract (spa = español)
TESSERACT_LANG=spa

# --- Matching ---
# Umbral de similitud para match automático (0.0 a 1.0)
# 0.8 = 80% de similitud → match automático
# Por debajo → pide confirmación al admin
FUZZY_THRESHOLD=0.8

# --- Logs ---
LOG_LEVEL=info
